---
import Layout from "../../components/Layout.astro";
---

<Layout title="Demos — @klinking/squircle">
  <h2 class="mb-6 text-2xl font-bold">Demos</h2>
  <p class="mb-8 text-zinc-400">
    Interactive sandboxes showing squircle in action. Edit the code live
    to experiment with squircle utilities.
  </p>

  <ul class="grid gap-4 sm:grid-cols-2">
    <li>
      <a
        href="/demos/react-basic"
        class="block rounded-lg border border-zinc-800 p-6 transition hover:border-indigo-500 hover:bg-zinc-900"
      >
        <h3 class="text-lg font-semibold">React + CSS-only</h3>
        <p class="mt-2 text-sm text-zinc-400">
          Compare regular rounded corners with squircle corners at different
          radii using Tailwind CSS utilities.
        </p>
      </a>
    </li>
  </ul>
</Layout>
