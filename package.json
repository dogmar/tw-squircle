{
  "name": "@klinking/tw-squircle",
  "version": "0.1.0",
  "description": "Tailwind CSS v4 squircle (superellipse) corner utilities with visual radius correction",
  "keywords": [
    "border-radius",
    "corner-shape",
    "squircle",
    "superellipse",
    "tailwind-plugin",
    "tailwindcss"
  ],
  "homepage": "https://dogmar.github.io/tw-squircle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dogmar/tw-squircle"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./squircle.css": "./dist/squircle.css",
    "./squircle-radius.css": "./dist/squircle-radius.css",
    "./merge": {
      "types": "./dist/merge.d.mts",
      "import": "./dist/merge.mjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.mts",
      "import": "./dist/plugin.mjs"
    }
  },
  "scripts": {
    "dev": "vite docs",
    "prepare": "vp config",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "oxlint": "^1.58.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "tailwind-merge": ">=2.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwind-merge": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0"
}
